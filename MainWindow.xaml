<Window x:Class="OrderManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:OrderManager"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="0*"/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <Grid Grid.ColumnSpan="2">
            <Button x:Name="lodbtn" Content="List Order Details" HorizontalAlignment="Left" Margin="10,100,0,0" VerticalAlignment="Top" Height="65" Width="153" Click="lodbtn_Click"/>
            <Button x:Name="aitobtn" Content="Add Item to Order" HorizontalAlignment="Left" Margin="163,100,0,0" VerticalAlignment="Top" Height="65" Width="153" Click="aitobtn_Click"/>
            <Button x:Name="exitbtn" Content="Exit" HorizontalAlignment="Left" Margin="316,100,0,0" VerticalAlignment="Top" Height="65" Width="153" Click="exitbtn_Click"/>
            <Label x:Name="lblBasket" Content="Basket" HorizontalAlignment="Left" Margin="10,165,0,0" VerticalAlignment="Top"/>
            <ComboBox x:Name="cmbBasket" HorizontalAlignment="Left" Margin="59,167,0,0" VerticalAlignment="Top" Width="410" IsReadOnly="True" SelectionChanged="cmbBasket_SelectionChanged"/>
            <DataGrid x:Name="dgBaskets" d:ItemsSource="{d:SampleData ItemCount=5}" Margin="10,191,10,10"/>
            <ComboBox x:Name="cmbBasket1" HorizontalAlignment="Left" Margin="264,195,0,0" VerticalAlignment="Top" Width="513"/>
            <Label x:Name="lblBasket2" Content="Basket" HorizontalAlignment="Left" Margin="211,195,0,0" VerticalAlignment="Top" RenderTransformOrigin="0.137,0.484"/>
            <Label x:Name="lblProduct" Content="Product" HorizontalAlignment="Left" Margin="211,220,0,0" VerticalAlignment="Top" RenderTransformOrigin="0.514,0.225"/>
            <ComboBox x:Name="cmbProducts" HorizontalAlignment="Left" Margin="264,222,0,0" VerticalAlignment="Top" Width="513"/>
            <Label x:Name="lblQuantity" Content="Quantity" HorizontalAlignment="Left" Margin="208,246,0,0" VerticalAlignment="Top" RenderTransformOrigin="0.581,-0.481"/>
            <TextBox x:Name="txtQuantity" HorizontalAlignment="Left" Margin="264,250,0,0" TextWrapping="Wrap" Text="TextBox" VerticalAlignment="Top" Width="513"/>
            <Button x:Name="btnSave" Content="Save" HorizontalAlignment="Left" Margin="49,333,0,0" VerticalAlignment="Top" Height="64" Width="306" Click="btnSave_Click"/>
            <Button x:Name="btnCancel" Content="Cancel" HorizontalAlignment="Left" Margin="434,333,0,0" VerticalAlignment="Top" Height="64" Width="306" Click="btnCancel_Click"/>
        </Grid>
        <Label x:Name="lblTitle" Content="Manage Orders" Margin="0,10,0,0" FontFamily="Papyrus" FontSize="24" HorizontalAlignment="Center" VerticalAlignment="Top" Width="764" Grid.Column="1" Height="89"/>
    </Grid>
</Window>